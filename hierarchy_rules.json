  "closing_rules": {
    "description": "Yönetmelik esaslarına göre kapanış ibaresi kuralları",
    "rules": {
      "sender_higher": {
        "description": "Gönderen üst makam, alıcı alt makam (üstten alta)",
        "expected_closing": "rica ederim.",
        "alternative_closings": ["Rica ederim"]
      },
      "sender_lower": {
        "description": "Gönderen alt makam, alıcı üst makam (alttan üste)",
        "expected_closing": "arz ederim.",
        "alternative_closings": ["Arz ederim"]
      },
      "sender_equal": {
        "description": "İdare içinde aynı düzey birimler arası yazışmalar (eşit düzey)",
        "expected_closing": "arz ederim.",
        "alternative_closings": ["Arz ederim"]
      },
      "mixed": {
        "description": "Üst + aynı + alt makamlara birlikte dağıtımlı yazışmalar",
        "expected_closing": "arz ve rica ederim.",
        "alternative_closings": ["Arz ve rica ederim", "Arz/rica ederim.", "Arz/rica ederim"]
      },
      "external_non_public": {
        "description": "Kamu niteliği olmayan tüzel kişilere (şirket, vakıf, dernek vb.)",
        "expected_closing": "rica ederim.",
        "alternative_closings": ["Rica ederim"]
      },
      "unknown": {
        "description": "Ast-üst ilişkisinin net tanımlanmadığı belirsiz durumlar",
        "expected_closing": "arz ederim.",
        "alternative_closings": ["Arz ederim"]
      }
    }
  },
  "delegation_rules": {
    "description": "Yetki devri (a.) durumunda arz/rica kararında esas alınacak işaretler",
    "notes": [
      "Belge, imza yetkisini devreden makam adına 'a.' imzalandığında karar yetkiyi devreden makamın hiyerarşik konumuna göre verilmelidir."
    ],
    "delegation_indicators": ["a.", "a./", "adına", "yerine", "vekili", "v."]
  },
  "distribution_rules": {
    "description": "Dağıtımlı yazılarda karma alıcı tespiti",
    "notes": [
      "Üst, aynı düzey ve alt makamlara birlikte dağıtımlı yazışmalar: 'Arz ve rica ederim.' veya 'Arz/rica ederim.'"
    ],
    "mixed_distribution_threshold": 2
  },
